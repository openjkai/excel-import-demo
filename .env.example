APP_NAME="Excel Import Demo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8090

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Database (use these values when running with Docker Compose)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=excel_import
DB_USERNAME=laravel
DB_PASSWORD=secret

# For local development without Docker, use your MySQL host:
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=excel_import
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

QUEUE_CONNECTION=database
CACHE_STORE=database

LOG_CHANNEL=stack
LOG_LEVEL=debug
